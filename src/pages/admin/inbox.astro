---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { InboxTable } from "@/components/InboxTable";
import { supabaseAdmin } from "@/lib/supabaseAdmin";

export const prerender = false;

const { data: messages, error } = await supabaseAdmin
  .from('inbox')
  .select('*')
  .order('created_at', { ascending: false });

console.log("LOG: Data Inbox Terambil ->", messages?.length);
if (error) console.error("LOG: Error Supabase ->", error.message);

console.log("--- DEBUG SERVER SIDE ---");
console.log("Jumlah Data Terambil:", messages?.length);
if (error) console.error("Error Detail:", error.message);

if (error) console.error(error);
---

<AdminLayout title="Inbox Pesan">
    <div class="space-y-6">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Inbox</h1>
            <p class="text-muted-foreground text-sm">Lihat dan kelola semua inbox kamu di sini</p>
        </div>

        <!-- <div class="bg-black text-green-400 p-4 rounded font-mono text-[10px] overflow-auto max-h-40">
            <p>// Raw Data Debugger</p>
            <p>Error: {JSON.stringify(error)}</p>
            <p>Count: {messages?.length}</p>
            <pre>{JSON.stringify(messages, null, 2)}</pre>
        </div> -->

        {/* Semua UI & logic tabel ada di sini */}
        <InboxTable client:load initialData={messages || []} />
    </div>
</AdminLayout>