---
import "@/styles/global.css";
import MainLayout from '../../layouts/MainLayout.astro';
import { DetailSection } from '../../components/DetailSection';
import { portoData } from '../../lib/data-porto';

export const prerender = true;

export async function getStaticPaths() {
    return portoData.map((porto) => ({
        params: { slug: porto.slug },
        props: { porto },
    }));
}

const { slug } = Astro.params;
const currentIndex = portoData.findIndex(p => p.slug === slug);
const porto = Astro.props.porto || portoData[currentIndex];

if (!porto) {
    return Astro.redirect('/404');
}

const relatedProjects = portoData.filter((p) => p.slug !== porto.slug).slice(0, 2);
const prevLink = currentIndex > 0 ? `/portofolio/${portoData[currentIndex - 1].slug}` : undefined;
const nextLink = currentIndex >= 0 && currentIndex < portoData.length - 1 ? `/portofolio/${portoData[currentIndex + 1].slug}` : undefined;
---

<MainLayout title={porto.title} postId={porto.id}>
    <DetailSection 
        data={porto} 
        relatedItems={relatedProjects} 
        type="portofolio"
        prevLink={prevLink}
        nextLink={nextLink}
        client:load 
    />
</MainLayout>