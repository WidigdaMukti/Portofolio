---
// src/pages/blog/[slug].astro
import "@/styles/global.css";
import MainLayout from '../../layouts/MainLayout.astro';
import { DetailSection } from '../../components/DetailSection';
import { blogData } from '../../lib/data-blog';

export const prerender = true;

export async function getStaticPaths() {
    return blogData.map((blog) => ({
        params: { slug: blog.slug },
        props: { blog },
    }));
}

const { slug } = Astro.params;
const currentIndex = blogData.findIndex(b => b.slug === slug);
const blog = Astro.props.blog || blogData[currentIndex];

if (!blog) {
    return Astro.redirect('/404');
}

const relatedBlogs = blogData.filter((b) => b.slug !== blog.slug).slice(0, 2);
const prevLink = currentIndex > 0 ? `/blog/${blogData[currentIndex - 1].slug}` : undefined;
const nextLink = currentIndex >= 0 && currentIndex < blogData.length - 1 ? `/blog/${blogData[currentIndex + 1].slug}` : undefined;
---

<MainLayout title={blog.title} postId={blog.id}>
    <DetailSection 
        data={blog} 
        relatedItems={relatedBlogs} 
        type="blog" 
        prevLink={prevLink}
        nextLink={nextLink}
        client:load 
    />
</MainLayout>
