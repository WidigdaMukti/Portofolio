---
// src/pages/blog/[slug].astro
import "@/styles/global.css";
import MainLayout from '../../layouts/MainLayout.astro';
import { DetailSection } from '../../components/DetailSection';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;

// 1. Fetch current blog
const { data: blogData } = await supabase
    .from('blogs')
    .select('*')
    .eq('slug', slug)
    .single();

if (!blogData) {
    return Astro.redirect('/404');
}

// 2. Fetch related blogs
const { data: relatedBlogs } = await supabase
    .from('blogs')
    .select('*')
    .eq('status', 'Published')
    .neq('slug', slug)
    .limit(2);

// 3. Fetch all published for prev/next logic
const { data: allBlogs } = await supabase
    .from('blogs')
    .select('slug')
    .eq('status', 'Published')
    .order('created_at', { ascending: false });

const currentIndex = allBlogs?.findIndex(b => b.slug === slug) ?? -1;
const prevLink = currentIndex > 0 ? `/blog/${allBlogs![currentIndex - 1].slug}` : undefined;
const nextLink = currentIndex >= 0 && currentIndex < (allBlogs?.length ?? 0) - 1 ? `/blog/${allBlogs![currentIndex + 1].slug}` : undefined;
// 4. Generate SEO Description from Content
const stripHtml = (html: string) => html.replace(/<[^>]*>?/gm, '');
const seoDescription = blogData.content ? stripHtml(blogData.content).substring(0, 160) + "..." : undefined;
---

<MainLayout 
    title={blogData.title} 
    postId={blogData.id}
    description={seoDescription}
    image={blogData.thumbnail}
    type="article"
>
    <DetailSection 
        data={blogData} 
        relatedItems={relatedBlogs || []} 
        type="blog" 
        prevLink={prevLink}
        nextLink={nextLink}
        client:load 
    />
</MainLayout>
