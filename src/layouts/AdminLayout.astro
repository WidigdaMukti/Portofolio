---
// src/layouts/AdminLayout.astro
import AdminPanel from "@/components/AdminPanel";
import { Toaster } from "@/components/ui/sonner";
import { supabaseAdmin } from "@/lib/supabaseAdmin";
import { supabase } from "@/lib/supabase";
import "@/styles/global.css";

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const { user } = Astro.locals;

// 1. HITUNG PESAN BARU (PAKAI ADMIN CLIENT AGAR TEMBUS RLS)
const { count: unreadCount } = await supabaseAdmin
  .from('inbox')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'new');

// 2. DATA LAIN (BISA PAKAI SUPABASE BIASA/ANON)
const { data: recentBlogs } = await supabase
  .from("blogs")
  .select("title, slug")
  .order("created_at", { ascending: false })
  .limit(5);

const { data: recentPortos } = await supabase
  .from("portofolios")
  .select("title, slug")
  .order("created_at", { ascending: false })
  .limit(5);

const userData = {
  id: user?.id || "", 
  name: user?.user_metadata?.full_name || user?.email?.split('@')[0] || "Admin",
  email: user?.email || "unknown@widigda.com",
  avatar: user?.user_metadata?.avatar_url || "", 
};
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} | Content Management System</title>
  </head>
  <body>
    <Toaster client:load richColors position="top-center" theme="light" />

    <AdminPanel 
      client:load 
      pathname={pathname} 
      user={userData}
      unreadCount={unreadCount || 0}
      recentBlogs={recentBlogs || []}
      recentPortos={recentPortos || []}
    >
      <slot />
    </AdminPanel>
  </body>
</html>